<header class="topbar">
    <a class="brand" href="/">
        <span class="logo">🌌</span>
        <span class="brandtext"><b>ASTRO EMPIRE</b><small>Command Console</small></span>
    </a>
    <nav class="topnav">
        {% if currentUser %}
            <span class="who">◢ {{ currentUser.username }}</span>
            <a class="navlink" href="/account">Account</a>
            <form method="POST" action="/logout" class="inline">
                <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                <button type="submit" class="navlink btn-link">Log out</button>
            </form>
        {% else %}
            <a class="navlink" href="/login">Log in</a>
            <a class="navlink primary" href="/register">Register</a>
        {% endif %}
    </nav>
</header>
