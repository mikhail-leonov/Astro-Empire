{% extends 'layout.twig' %}
{% block content %}
<section class="card">
  <h2>Database setup</h2>
  <p class="muted">Connect Astro Empire to a MySQL database. This only runs once — settings are saved to <code>.env</code>.</p>
  {% if errors._form %}<div class="flash flash-error">{{ errors._form }}</div>{% endif %}
  <form method="post" action="/setup">
    <input type="hidden" name="_csrf" value="{{ csrfToken }}">
    <div class="grid-2">
      <div class="field">
        <label for="host">Host</label>
        <input id="host" name="host" value="{{ old.host|default('127.0.0.1') }}" class="{{ errors.host ? 'is-invalid' : '' }}">
        {% if errors.host %}<small class="err">{{ errors.host }}</small>{% endif %}
      </div>
      <div class="field">
        <label for="port">Port</label>
        <input id="port" name="port" value="{{ old.port|default('3306') }}" class="{{ errors.port ? 'is-invalid' : '' }}">
        {% if errors.port %}<small class="err">{{ errors.port }}</small>{% endif %}
      </div>
    </div>
    <div class="grid-2">
      <div class="field">
        <label for="user">Database user</label>
        <input id="user" name="user" value="{{ old.user|default('root') }}" class="{{ errors.user ? 'is-invalid' : '' }}">
        {% if errors.user %}<small class="err">{{ errors.user }}</small>{% endif %}
      </div>
      <div class="field">
        <label for="password">Password</label>
        <input id="password" type="password" name="password">
      </div>
    </div>
    <div class="field">
      <label for="database">Database name</label>
      <input id="database" name="database" value="{{ old.database|default('astro_empire') }}" class="{{ errors.database ? 'is-invalid' : '' }}">
      {% if errors.database %}<small class="err">{{ errors.database }}</small>{% else %}<small class="hint">Created automatically if it doesn't exist yet.</small>{% endif %}
    </div>
    <button class="btn primary btn-block" type="submit">Connect &amp; initialize</button>
  </form>
</section>
{% endblock %}
