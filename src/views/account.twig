{% extends "layout.twig" %}
{% block content %}
<section class="card account-card">
    <h2>Your account</h2>

    <dl class="profile">
        <div><dt>Username</dt><dd>{{ account.username }}</dd></div>
        <div><dt>Email</dt><dd>{{ account.email }}</dd></div>
        <div><dt>Role</dt><dd>{{ account.role }}</dd></div>
        <div><dt>Account tier</dt><dd>{{ account.tierName }}</dd></div>
        <div><dt>Member since</dt><dd>{{ account.created_at | date('M j, Y') }}</dd></div>
        <div><dt>Last login</dt><dd>{{ account.last_seen | date('M j, Y · H:i') }}</dd></div>
    </dl>

    <div class="account-actions">
        <a class="btn btn-primary" href="/play">▸ Enter the Galaxy</a>
        <form method="POST" action="/logout" class="inline">
            <input type="hidden" name="_csrf" value="{{ csrfToken }}">
            <button type="submit" class="btn btn-ghost">Log out</button>
        </form>
    </div>
</section>

<section class="card danger-card">
    <h3>Danger zone</h3>
    <p class="muted">Deleting your account is permanent and cannot be undone.</p>
    <form method="POST" action="/account/delete" data-confirm="Delete your account permanently? This cannot be undone.">
        <input type="hidden" name="_csrf" value="{{ csrfToken }}">
        <button type="submit" class="btn btn-danger">Delete my account</button>
    </form>
</section>
{% endblock %}
