{% extends 'layout.twig' %}
{% block content %}
<section class="card">
  <h2>Account</h2>
  <p class="muted">Commander profile &amp; subscription tier.</p>
  <dl class="profile">
    <div><dt>Username</dt><dd>{{ account.username }}</dd></div>
    <div><dt>Email</dt><dd>{{ account.email }}</dd></div>
    <div><dt>Role</dt><dd>{{ account.role }}</dd></div>
    <div><dt>Tier</dt><dd>{{ account.tierName }}</dd></div>
    <div><dt>Joined</dt><dd>{{ account.createdAt|date('Y-m-d') }}</dd></div>
    <div><dt>Last seen</dt><dd>{{ account.lastSeen|date('Y-m-d H:i') }}</dd></div>
  </dl>
  <div class="account-actions">
    <a class="btn primary" href="/play">▶ Play</a>
    {% if account.role == 'admin' %}<a class="btn ghost" href="/admin">Admin panel</a>{% endif %}
  </div>

  <h3>Danger zone</h3>
  <div class="card danger-card">
    <p class="muted">Deleting your account permanently removes your empire, bases, fleets and login. This cannot be undone.</p>
    <form method="post" action="/account/delete" data-confirm="Permanently delete your account and empire? This cannot be undone.">
      <input type="hidden" name="_csrf" value="{{ csrfToken }}">
      <button class="btn danger" type="submit">Delete account</button>
    </form>
  </div>
</section>
{% endblock %}
