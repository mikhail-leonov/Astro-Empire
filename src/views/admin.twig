{% extends 'layout.twig' %}
{% block content %}
<section class="card admin-card">
  <h2>Admin · Accounts</h2>
  <p class="muted">Manage commander accounts and account tiers.</p>

  <h3>Accounts</h3>
  <table class="admin-table">
    <thead><tr><th>ID</th><th>Username</th><th>Email</th><th>Tier</th><th>Role</th><th></th></tr></thead>
    <tbody>
    {% for a in accounts %}
      <tr>
        <form method="post" action="/admin/users/{{ a.id }}">
        <input type="hidden" name="_csrf" value="{{ csrfToken }}">
        <td>{{ a.id }}</td>
        <td><input name="username" value="{{ a.username }}"></td>
        <td><input name="email" value="{{ a.email }}"></td>
        <td>
          <select name="tierId">
            {% for t in tiers %}<option value="{{ t.id }}" {{ t.id == a.tier_id ? 'selected' : '' }}>{{ t.name }}</option>{% endfor %}
          </select>
        </td>
        <td>
          <select name="role">
            <option value="user" {{ a.role == 'user' ? 'selected' : '' }}>user</option>
            <option value="admin" {{ a.role == 'admin' ? 'selected' : '' }}>admin</option>
          </select>
        </td>
        <td class="admin-actions">
          <button class="btn sm primary" type="submit">Save</button>
        </td>
        </form>
        <td>
          <form method="post" action="/admin/users/{{ a.id }}/delete" data-confirm="Delete account {{ a.username }}?">
            <input type="hidden" name="_csrf" value="{{ csrfToken }}">
            <button class="btn sm danger" type="submit">Delete</button>
          </form>
        </td>
      </tr>
    {% endfor %}
    </tbody>
  </table>

  <h3>Account tiers</h3>
  <table class="admin-table">
    <thead><tr><th>Code</th><th>Name</th><th>Description</th><th>Max bases</th><th>Max queue</th><th>Sort</th><th></th></tr></thead>
    <tbody>
    {% for t in tiers %}
      <tr>
        <form method="post" action="/admin/tiers/{{ t.id }}">
        <input type="hidden" name="_csrf" value="{{ csrfToken }}">
        <td><input name="code" value="{{ t.code }}"></td>
        <td><input name="name" value="{{ t.name }}"></td>
        <td><input name="description" value="{{ t.description }}"></td>
        <td><input class="num" type="number" name="maxBases" value="{{ t.max_bases }}"></td>
        <td><input class="num" type="number" name="maxQueue" value="{{ t.max_queue }}"></td>
        <td><input class="num" type="number" name="sortOrder" value="{{ t.sort_order }}"></td>
        <td class="admin-actions"><button class="btn sm primary" type="submit">Save</button></td>
        </form>
        <td>
          <form method="post" action="/admin/tiers/{{ t.id }}/delete" data-confirm="Delete tier {{ t.name }}?">
            <input type="hidden" name="_csrf" value="{{ csrfToken }}">
            <button class="btn sm danger" type="submit">Delete</button>
          </form>
        </td>
      </tr>
    {% endfor %}
    </tbody>
  </table>

  <h3>New tier</h3>
  <form method="post" action="/admin/tiers" class="admin-newtier">
    <input type="hidden" name="_csrf" value="{{ csrfToken }}">
    <div class="field"><label>Code</label><input name="code" required></div>
    <div class="field"><label>Name</label><input name="name" required></div>
    <div class="field"><label>Description</label><input name="description"></div>
    <div class="field"><label>Max bases</label><input class="num" type="number" name="maxBases" value="3"></div>
    <div class="field"><label>Max queue</label><input class="num" type="number" name="maxQueue" value="1"></div>
    <div class="field"><label>Sort</label><input class="num" type="number" name="sortOrder" value="0"></div>
    <button class="btn primary" type="submit">Create tier</button>
  </form>
</section>
{% endblock %}
